local function LoadBackroomsMap()
    local mapID = 10581711055
    local success, model = pcall(function()
        return game:GetObjects("rbxassetid://" .. mapID)[1]
    end)
    if not success or not model then return false end
    local targetPos = Vector3.new(0, 10000, 0)
    model.Parent = Workspace
    local primary = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
    if primary then
        local offset = targetPos - primary.Position
        for _, v in ipairs(model:GetDescendants()) do
            if v:IsA("BasePart") then
                v.CFrame = v.CFrame + offset
            end
        end
    end
    return true
end

-- Jail melhorada: vermelha transparente e com loop para prender
local function CreateJail()
    -- Se já existir uma jail, destrói antes
    if JailModel then
        JailModel:Destroy()
        JailModel = nil
    end
    if JailLoop then
        JailLoop:Disconnect()
        JailLoop = nil
    end

    local root = HRP()
    if not root then return end
    
    local basePos = root.Position
    local jailSize = 14        -- tamanho
    local height = 10          -- altura
    local wallThickness = 0.5
    local transparency = 0.7   -- transparente (0 = opaco, 1 = invisível)
    local color = Color3.fromRGB(255, 0, 0) -- vermelho
    
    JailModel = Instance.new("Model", Workspace)
    JailModel.Name = "SpectraJail"
    
    local function createPart(size, position)
        local part = Instance.new("Part")
        part.Size = size
        part.Position = position
        part.Anchored = true
        part.CanCollide = true
        part.Material = Enum.Material.Glass
        part.Color = color
        part.Transparency = transparency
        part.BrickColor = BrickColor.new("Really red")
        part.Parent = JailModel
        return part
    end
    
    -- Paredes (caixa)
    createPart(Vector3.new(wallThickness, height, jailSize), basePos + Vector3.new(jailSize/2, height/2, 0))
    createPart(Vector3.new(wallThickness, height, jailSize), basePos + Vector3.new(-jailSize/2, height/2, 0))
    createPart(Vector3.new(jailSize, height, wallThickness), basePos + Vector3.new(0, height/2, jailSize/2))
    createPart(Vector3.new(jailSize, height, wallThickness), basePos + Vector3.new(0, height/2, -jailSize/2))
    
    -- Teto e chão
    createPart(Vector3.new(jailSize, wallThickness, jailSize), basePos + Vector3.new(0, height, 0))
    createPart(Vector3.new(jailSize, wallThickness, jailSize), basePos + Vector3.new(0, 0, 0))
    
    -- Centro da jaula
    local center = basePos + Vector3.new(0, height/2, 0)
    
    -- Loop para manter o jogador dentro
    JailLoop = RunService.Heartbeat:Connect(function()
        if not JailModel or not JailModel.Parent then
            if JailLoop then
                JailLoop:Disconnect()
                JailLoop = nil
            end
            return
        end
        local hrp = HRP()
        if hrp then
            local dist = (hrp.Position - center).Magnitude
            if dist > jailSize/2 - 1 then
                hrp.CFrame = CFrame.new(center)
                hrp.Velocity = Vector3.new(0, 0, 0)
            end
        end
    end)
end


                } 

                for _, pattern in ipairs(movePatterns) do 
                    if not flingLoop then break end 
                    pcall(function() 
                        vehicle:SetPrimaryPartCFrame(CFrame.new(targetRoot.Position) * pattern.pos * pattern.rot) 
                    end) 
                    task.wait(0.1) 
                end 

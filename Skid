            SendNotification("Auto Fling", "ATIVADO - Alvo: " .. Global.LockedTarget)

            task.spawn(function()
                while Global.AutoFlingActive do
                    task.wait(1)

                    if not Global.LockedTarget or Global.LockedTarget == "" then
                        SendNotification("Auto Fling", "Alvo perdido")
                        Global.AutoFlingActive = false
                        break
                    end

                    local currentTarget = Players:FindFirstChild(Global.LockedTarget)

                    if not currentTarget then
                        SendNotification("Auto Fling", Global.LockedTarget .. " saiu do jogo")
                        Global.AutoFlingActive = false
                        break
                    end

                    local waitTime = 0
                    while (not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart")) and waitTime < 10 do
                        task.wait(0.5)
                        waitTime = waitTime + 0.5
                    end

                    if not LocalPlayer.Character or not currentTarget.Character then
                        continue
                    end

                    if not currentTarget.Character:FindFirstChild("HumanoidRootPart") then
                        continue
                    end

                    pcall(function()
                        if Global.SelectedMethod == "Ball" then
                            FlingBall(currentTarget)
                            task.wait(2)
                        elseif Global.SelectedMethod == "Couch" then
                            KillCouch(currentTarget)
                            task.wait(3)
                        end
                    end)
                end
            end)
        else
            SendNotification("Auto Fling", "Desativado")
        end
    end
})


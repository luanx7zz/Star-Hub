function StartNoclip()
    if NoclipConnection then return end
    NoclipConnection = RunService.Stepped:Connect(function()
        pcall(function()
            if LocalPlayer.Character then
                for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
            if CurrentCar then
                for _, part in ipairs(CurrentCar:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end)
    end)
end

function StopNoclip()
    if NoclipConnection then
        NoclipConnection:Disconnect()
        NoclipConnection = nil
    end
end

function MakeCarInvisible(car)
    pcall(function()
        for _, part in ipairs(car:GetDescendants()) do
            if part:IsA("BasePart") or part:IsA("Decal") then
                part.Transparency = 1
            end
        end
    end)
end

function SpawnCar()
    local RE_Folder = ReplicatedStorage:FindFirstChild("RE")
    if RE_Folder and RE_Folder:FindFirstChild("1Ca1r") then
        RE_Folder["1Ca1r"]:FireServer("PickingCar", "KeiTruck")

        local CarName = LocalPlayer.Name .. "Car"
        local car = nil
        local timeout = 0
        repeat 
            task.wait(0.1)
            car = Workspace:FindFirstChild("Vehicles") and Workspace.Vehicles:FindFirstChild(CarName)
            timeout = timeout + 1
        until (car and car:FindFirstChild("Seats")) or timeout > 40
        return car
    end
    return nil
end

function StopFling()
    FlingEnabled = false
    StopNoclip()

    pcall(function()
        ReplicatedStorage.RE:FindFirstChild("1Ca1r"):FireServer("DeleteAllVehicles")
    end)

    pcall(function()
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChild("Humanoid")
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")

        if humanoid then humanoid.Sit = false end
        if CurrentCar then 
            CurrentCar:Destroy()
            CurrentCar = nil 
        end

        if TogglePosition and character and rootPart then 
            rootPart.Velocity = Vector3.new(0,0,0)
            rootPart.RotVelocity = Vector3.new(0,0,0)
            character:PivotTo(TogglePosition)
            rootPart.Anchored = true
            task.wait(0.5)
            rootPart.Anchored = false
        end
    end)
end

function StartFling()
    if not Global.SelectedPlayer then return end
    local Target = Players:FindFirstChild(Global.SelectedPlayer)
    if not Target or not Target.Character then return end

    StartNoclip()
    LocalPlayer.Character:PivotTo(SpawnCFrame)
    task.wait(0.4)
    CurrentCar = SpawnCar()

    if not CurrentCar then return StopFling() end
    MakeCarInvisible(CurrentCar)

    local angle = 0
    while FlingEnabled do
        local success, err = pcall(function()
            if not CurrentCar or not CurrentCar.Parent then
                CurrentCar = SpawnCar()
                if CurrentCar then MakeCarInvisible(CurrentCar) end
            end

            local TargetChar = Target.Character
            local MyChar = LocalPlayer.Character

            if TargetChar and TargetChar:FindFirstChild("HumanoidRootPart") and MyChar and MyChar:FindFirstChild("Humanoid") then
                local root = TargetChar.HumanoidRootPart
                local hum = MyChar.Humanoid
                local seat = CurrentCar:FindFirstChildWhichIsA("VehicleSeat", true) or CurrentCar:FindFirstChildWhichIsA("Seat", true)

                if seat and hum.SeatPart ~= seat then
                    seat:Sit(hum)
                end

                for _, part in ipairs(CurrentCar:GetDescendants()) do
                    if part:IsA("BasePart") then
                        pcall(function() part:SetNetworkOwner(LocalPlayer) end)

                        if not part:FindFirstChild("TornadoForce") then
                            local bv = Instance.new("BodyVelocity", part)
                            bv.Name = "TornadoForce"
                            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
                            bv.P = 9000 

                            local bav = Instance.new("BodyAngularVelocity", part)
                            bav.Name = "UltraSpin"
                            bav.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                            bav.P = 9000
                        end
                        part.TornadoForce.Velocity = Vector3.new(5000, 5000, 5000) 
                        part.UltraSpin.AngularVelocity = Vector3.new(0, 6000, 0)
                    end
                end

                angle = angle + 90 
                local offset = CFrame.Angles(0, math.rad(angle), 0) * CFrame.new(0.1, -0.1, 0)
                CurrentCar:PivotTo(root.CFrame * offset)
            end
        end)

        if not success then task.wait(0.1) end
        RunService.Heartbeat:Wait()
    end
    StopFling()
end


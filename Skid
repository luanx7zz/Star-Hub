local function getESPColor()
    local colors = {
        RGB = function() 
            local h = (tick() % 5) / 5
            return Color3.fromHSV(h, 1, 1)
        end,
        Preto = Color3.fromRGB(0, 0, 0),
        Branco = Color3.fromRGB(255, 255, 255),
        Vermelho = Color3.fromRGB(255, 0, 0),
        Verde = Color3.fromRGB(0, 255, 0),
        Azul = Color3.fromRGB(0, 170, 255),
        Amarelo = Color3.fromRGB(255, 255, 0),
        Rosa = Color3.fromRGB(255, 105, 180),
        Roxo = Color3.fromRGB(128, 0, 128)
    }

    local selectedColor = colors[Global.ESPData.selectedColor]
    if type(selectedColor) == "function" then
        return selectedColor()
    end
    return selectedColor or Color3.new(1, 1, 1)
end

local function clearAllESP()
    for _, gui in pairs(Global.ESPData.billboardGuis) do
        if gui then pcall(function() gui:Destroy() end) end
    end
    Global.ESPData.billboardGuis = {}

    for _, hl in pairs(Global.ESPData.highlights) do
        if hl then pcall(function() hl:Destroy() end) end
    end
    Global.ESPData.highlights = {}

    for _, ln in pairs(Global.ESPData.lines) do
        if ln then pcall(function() ln:Remove() end) end
    end
    Global.ESPData.lines = {}
end


local function resolve(path)
    local obj = Workspace
    for seg in string.gmatch(path, "[^%.]+") do
        obj = obj:FindFirstChild(seg)
        if not obj then return nil end
    end
    return obj
end

local function click(cd)
    if not cd then return end
    pcall(function()
        if fireclickdetector then
            fireclickdetector(cd)
        end
    end)
end

local alignPos, alignOri = nil, nil
local function fixarNoCFrame(char, cf)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if alignPos then alignPos:Destroy() end
    if alignOri then alignOri:Destroy() end

    alignPos = Instance.new("AlignPosition")
    alignOri = Instance.new("AlignOrientation")

    alignPos.MaxForce = math.huge
    alignPos.Responsiveness = 200
    alignOri.MaxTorque = math.huge
    alignOri.Responsiveness = 200

    local attachment = Instance.new("Attachment", hrp)
    local worldAttach = Instance.new("Attachment", Workspace.Terrain)
    worldAttach.WorldCFrame = cf

    alignPos.Attachment0 = attachment
    alignPos.Attachment1 = worldAttach
    alignOri.Attachment0 = attachment
    alignOri.Attachment1 = worldAttach

    alignPos.Parent = hrp
    alignOri.Parent = hrp
end

local function soltar()
    if alignPos then 
        alignPos:Destroy() 
        alignPos = nil 
    end
    if alignOri then 
        alignOri:Destroy() 
        alignOri = nil 
    end
end


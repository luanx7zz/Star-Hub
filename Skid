local function getAllCars()
    local cars = {}
    local vehiclesFolder = game.Workspace:FindFirstChild("Vehicles")
    
    if vehiclesFolder then
        for _, vehicle in pairs(vehiclesFolder:GetChildren()) do
            if vehicle:IsA("Model") then
                local seat = vehicle:FindFirstChild("VehicleSeat") or 
                            vehicle:FindFirstChildWhichIsA("VehicleSeat", true)
                
                if seat then
                    local ownerName = "Desconhecido"
                    local owner = vehicle:FindFirstChild("Owner")
                    
                    if owner and owner.Value then
                        ownerName = owner.Value
                    elseif seat:FindFirstChild("PlayerName") and seat.PlayerName.Value then
                        ownerName = seat.PlayerName.Value
                    end
                    
                    table.insert(cars, {
                        Model = vehicle,
                        DisplayName = string.format("%s (%s)", vehicle.Name, ownerName),
                        CarName = vehicle.Name
                    })
                end
            end
        end
    end
    
    return cars
end

local function getCarNames()
    local cars = getAllCars()
    local names = {"Nenhum"}
    
    for _, carData in ipairs(cars) do
        table.insert(names, carData.DisplayName)
    end
    
    return names
end


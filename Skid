ChildTab:AddToggle({
    Name = "Waist Loop (Front/Back)",
    Default = false,
    Callback = function(Value)
        waistLoopEnabled = Value

        if Value then
            if not chasingplayer then
                waistLoopEnabled = false
                return
            end

            if rawget(getgenv(), "WaistLoopConn") then
                getgenv().WaistLoopConn:Disconnect()
            end

--------Teste
            local t = 0
            local frontDistance = 0.1
            local backDistance = 3.5
            local speed = 7
            local waistDownOffset = 0.6

            getgenv().WaistLoopConn = RunService.Heartbeat:Connect(function(dt)
                if not waistLoopEnabled or not chasingplayer then
                    if rawget(getgenv(), "WaistLoopConn") then
                        getgenv().WaistLoopConn:Disconnect()
                        getgenv().WaistLoopConn = nil
                    end
                    return
                end

                local target = workspace:FindFirstChild(chasingplayer)
                if not target then return end

                local hrp = target:FindFirstChild("HumanoidRootPart")
                local follow = target:FindFirstChild("FollowCharacter")

                if hrp and follow and follow:FindFirstChild("Torso") then
                    local torso = follow.Torso
                    local bp = torso:FindFirstChild("BodyPosition")
                    local bg = torso:FindFirstChild("BodyGyro")
                    if not bp or not bg then return end

                    t += dt * speed
                    local oscillation = math.sin(t)
                    local currentDistance = frontDistance + (backDistance - frontDistance) * ((oscillation + 1) / 2)

                    bp.Position =
                        hrp.Position
                        - (hrp.CFrame.LookVector * currentDistance)
                        - Vector3.new(0, waistDownOffset, 0)

                    bg.CFrame = hrp.CFrame
                end
            end)
        else
            if rawget(getgenv(), "WaistLoopConn") then
                getgenv().WaistLoopConn:Disconnect()
                getgenv().WaistLoopConn = nil
            end
        end
    end
})


            local heightOffset = 
                math.sin(time * 2) * heightVariation + 
                math.cos(time * 3.5) * (heightVariation * 0.6) +
                math.sin(time * 5) * (heightVariation * 0.3)
            
            -- Movimento lateral caótico
            local lateralOffsetX = math.sin(lateralTime) * lateralRange + math.cos(time * chaosSpeed * 0.8) * (lateralRange * 0.5)
            local lateralOffsetZ = math.cos(lateralTime * 0.7) * lateralRange * 0.8 + math.sin(time * chaosSpeed * 1.2) * (lateralRange * 0.3)
            
            -- Posição final com instabilidade usando CFrame
            local finalPos = Vector3.new(
                basePos.X + lateralOffsetX,
                baseHeight + heightOffset,  -- ALTURA BASE 25 + VARIAÇÃO
                basePos.Z + lateralOffsetZ
            )
            
            -- Rotações caóticas usando CFrame.Angles
            local rotX = math.sin(time * 4) * 0.5 + math.cos(time * 2.5) * 0.3
            local rotY = spinAngle + math.sin(time * 1.5) * 2
            local rotZ = math.cos(time * 3.5) * 0.5 + math.sin(time * 6) * 0.25
            
            -- Criar CFrame completo
            local finalCFrame = CFrame.new(finalPos) * CFrame.Angles(rotX, rotY, rotZ)
            
            -- Adicionar tremor extra
            local tremorX = math.random(-100, 100) / 1000
            local tremorZ = math.random(-100, 100) / 1000
            finalCFrame = finalCFrame * CFrame.new(tremorX, 0, tremorZ)
            
            -- Aplicar CFrame ao Seat
            pcall(function()
                if Humanoid.SeatPart == Seat then
                    Seat.CFrame = finalCFrame
                    
                    -- MANTER PERSONAGEM NO BARCO SEMPRE
                    if RootPart and RootPart.Parent then
                        RootPart.CFrame = finalCFrame * CFrame.new(0, 3, 0)  -- Ligeiramente acima do seat
                    end
                end
            end)
        end)
        
        table.insert(_G.TornadoConnections, heartbeat)
        
        -- CONEXÃO PARA IMPEDIR O PERSONAGEM DE SAIR DO BARCO
        local seatCheckConnection = RunService.Heartbeat:Connect(function()
            if Humanoid.SeatPart ~= Seat and _G.TornadoActive then
                -- Forçar personagem a sentar novamente
                pcall(function()
                    if Seat and Seat.Parent and PCar and PCar.Parent then
                        Humanoid.Sit = true
                        RootPart.CFrame = Seat.CFrame * CFrame.new(0, 1, 0)
                    end
                end)
            end
        end)
        
        table.insert(_G.TornadoConnections, seatCheckConnection)
        
        -- NÃO EJECTAR MAIS O JOGADOR - ELE FICA NO BARCO
        task.delay(5, function()
            print("[Tornado] Jogador permanece no barco! Tornado instável ativo.")
        end)
        

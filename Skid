Troll:AddButton({
    Name = "Start Fling",
    Callback = function()
        if not selectedCar or not selectedCar.Parent then
            warn("Nenhum carro selecionado ou carro não existe")
            return
        end

        local Player = game.Players.LocalPlayer
        local Character = Player.Character
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
        local Vehicles = game.Workspace:FindFirstChild("Vehicles")

        if not Humanoid or not RootPart then
            warn("Humanoid ou RootPart invalidos")
            return
        end

        lastPosition = RootPart.CFrame
        print("Posicao salva")

        local targetCar = selectedCar
        local targetSeat = targetCar:FindFirstChild("VehicleSeat") or 
                          targetCar:FindFirstChildWhichIsA("VehicleSeat", true)

        if not targetSeat then
            warn("Assento nao encontrado no carro alvo")
            return
        end

        local function spawnPirateBoat()
            RootPart.CFrame = CFrame.new(1754, -2, 58)
            task.wait(0.5)
            game:GetService("ReplicatedStorage").RE:FindFirstChild("1Ca1r"):FireServer("PickingBoat", "PirateFree")
            task.wait(1)
            
            for _, vehicle in pairs(Vehicles:GetChildren()) do
                if vehicle:IsA("Model") and (vehicle.Name:find(Player.Name) or vehicle.Name:find("Pirate")) then
                    return vehicle
                end
            end
            
            for _, vehicle in pairs(Vehicles:GetChildren()) do
                if vehicle:IsA("Model") then
                    local seat = vehicle:FindFirstChild("Body") and vehicle.Body:FindFirstChild("VehicleSeat")
                    if seat then
                        return vehicle
                    end
                end
            end
            
            return nil
        end

        pirateBoat = spawnPirateBoat()
        if not pirateBoat then
            warn("Falha ao spawnar barco pirata")
            return
        end

        local pirateSeat = pirateBoat:FindFirstChild("Body") and pirateBoat.Body:FindFirstChild("VehicleSeat")
        if not pirateSeat then
            warn("Assento do barco nao encontrado")
            return
        end

        repeat 
            task.wait(0.1)
            RootPart.CFrame = pirateSeat.CFrame * CFrame.new(0, 1, 0)
        until Humanoid.SeatPart == pirateSeat

        print("Barco pirata spawnado e sentado")

        local Spin = Instance.new("BodyAngularVelocity")
        Spin.Name = "Spinning"
        Spin.Parent = pirateBoat.PrimaryPart or pirateSeat.Parent
        Spin.MaxTorque = Vector3.new(0, math.huge, 0)
        Spin.AngularVelocity = Vector3.new(0, 500, 0)

        flingActive = true
        print("Fling iniciado com barco pirata")

        task.spawn(function()
            while pirateBoat and pirateBoat.Parent and targetCar and targetCar.Parent and flingActive do
                task.wait(0.01)
                
                local primaryPart = pirateBoat.PrimaryPart or pirateSeat.Parent
                local targetPrimary = targetCar.PrimaryPart or targetSeat
                
                if primaryPart and targetPrimary then
                    local targetPos = targetPrimary.Position
                    
                    primaryPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 2, 0))
                    task.wait(0.01)
                    primaryPart.CFrame = CFrame.new(targetPos + Vector3.new(3, 1, 0))
                    task.wait(0.01)
                    primaryPart.CFrame = CFrame.new(targetPos + Vector3.new(-3, 1, 0))
                    task.wait(0.01)
                    primaryPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 1, 3))
                    task.wait(0.01)
                    primaryPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 1, -3))
                    task.wait(0.01)
                    
                    local randomRotation = CFrame.Angles(
                        math.rad(math.random(-180, 180)),
                        math.rad(math.random(-180, 180)),
                        math.rad(math.random(-180, 180))
                    )
                    primaryPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 2, 0)) * randomRotation
                end
            end

            if Spin and Spin.Parent then
                Spin:Destroy()
                print("Spin removido")
            end
        end)
    end
})

Troll:AddButton({
    Name = "Stop Fling",
    Callback = function()
        local Player = game.Players.LocalPlayer
        local Character = Player.Character
        local RootPart = Character and Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
        local Vehicles = game.Workspace:FindFirstChild("Vehicles")

        if not RootPart or not Humanoid then
            warn("RootPart ou Humanoid nao encontrados")
            return
        end

        flingActive = false
        print("Fling desativado")

        for _, obj in pairs(RootPart:GetChildren()) do
            if obj:IsA("BodyAngularVelocity") or obj:IsA("BodyVelocity") or obj:IsA("BodyGyro") or obj:IsA("BodyPosition") then
                obj:Destroy()
            end
        end

        if pirateBoat and pirateBoat.Parent then
            local primaryPart = pirateBoat.PrimaryPart or (pirateBoat:FindFirstChild("Body") and pirateBoat.Body:FindFirstChild("VehicleSeat"))
            if primaryPart then
                for _, obj in pairs(primaryPart:GetChildren()) do
                    if obj:IsA("BodyAngularVelocity") or obj:IsA("BodyVelocity") then
                        obj:Destroy()
                    end
                end
            end
            
            pirateBoat:Destroy()
            print("Barco pirata removido")
        end

        if Vehicles then
            for _, vehicle in pairs(Vehicles:GetChildren()) do
                if vehicle:IsA("Model") and (vehicle.Name:find(Player.Name) or vehicle.Name:find("Pirate")) then
                    vehicle:Destroy()
                end
            end
        end

        task.wait(0.3)

        if Humanoid.SeatPart then
            Humanoid.Sit = false
            task.wait(0.2)
        end

        Humanoid.PlatformStand = true
        RootPart.Velocity = Vector3.zero
        RootPart.RotVelocity = Vector3.zero

        if lastPosition then
            print("Teleportando para posicao anterior")
            
            local bp = Instance.new("BodyPosition", RootPart)
            bp.Position = lastPosition.Position
            bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bp.P = 10000
            bp.D = 500

            local bg = Instance.new("BodyGyro", RootPart)
            bg.CFrame = lastPosition
            bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bg.P = 10000
            bg.D = 500

            task.wait(2)

            bp:Destroy()
            bg:Destroy()
            
            RootPart.CFrame = lastPosition
            print("Jogador retornou para posicao anterior")
        end

        Humanoid.PlatformStand = false
        RootPart.Velocity = Vector3.zero
        RootPart.RotVelocity = Vector3.zero

        print("Sistema desligado completamente")
    end
})


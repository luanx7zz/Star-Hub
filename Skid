    local lotsFolder = workspace:FindFirstChild("001_Lots")
    if lotsFolder then
        for _, house in ipairs(lotsFolder:GetChildren()) do
            if house:IsA("Model") then
                table.insert(HouseNames, house.Name)
            end
        end
    end
    table.sort(HouseNames)
    return HouseNames
end


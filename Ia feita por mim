-- Função unificada (evita código duplicado entre botão e Enter)
local function SendMessage()
    if isAIResponding then
        -- Cancelar resposta em andamento
        isAIResponding = false
        if currentAIRequest then task.cancel(currentAIRequest); currentAIRequest = nil end
        UpdateSendIcon("circle-arrow-up", Color3.fromRGB(255, 140, 0))
        for _, child in ipairs(G2L["ScrollingFrame_c"]:GetChildren()) do
            if child.Name == "LoadingMessage" then child:Destroy() end
        end
        AddMessage("System", "Resposta cancelada.", false)
        return
    end

    local userMessage = G2L["TextBox_f"].Text
    if userMessage:gsub("%s+", "") == "" then return end

    AddMessage("Você", userMessage, true)
    G2L["TextBox_f"].Text = ""

    UpdateSendIcon("circle-stop", Color3.fromRGB(255, 60, 60))
    isAIResponding = true

    local loadingMsg, stopAnim = ShowLoadingMessage()

    currentAIRequest = task.spawn(function()
        local aiResponse = CallAI(userMessage)

        if isAIResponding then
            stopAnim()
            if loadingMsg and loadingMsg.Parent then loadingMsg:Destroy() end

            -- Atualiza histórico de conversa (mantém até 20 mensagens = 10 turnos)
            table.insert(conversationHistory, { role = "user",      content = userMessage })
            table.insert(conversationHistory, { role = "assistant", content = aiResponse  })
            while #conversationHistory > 20 do table.remove(conversationHistory, 1) end

            DisplayAIResponse(aiResponse)
        end

        isAIResponding   = false
        currentAIRequest = nil
        UpdateSendIcon("circle-arrow-up", Color3.fromRGB(255, 140, 0))
    end)
end


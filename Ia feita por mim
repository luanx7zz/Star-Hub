-- ── Dispatcher ─────────────────────────────────────────────────────────────
local function CallAI(userMessage)
    if     currentAI == "Pollinations"     then return CallPollinationsAPI(userMessage)
    elseif currentAI == "Gemini"           then return CallGeminiAPI(userMessage)
    elseif currentAI == "(Groq) Llama"     then return CallGroqAPI(userMessage, "llama-3.3-70b-versatile")
    elseif currentAI == "(Groq) Compound"  then return CallGroqAPI(userMessage, "compound-beta")
    elseif currentAI == "Claude"           then return CallClaudeAPI(userMessage)
    elseif currentAI == "ChatGPT 4o"       then return CallChatGPTAPI(userMessage)
    else   return "Selecione um modelo de IA nas configurações" end
end


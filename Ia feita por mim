local function AddMessage(sender, message, isUser)
    local label = Instance.new("TextLabel")
    label.LayoutOrder       = NextOrder()
    label.Size              = UDim2.new(1, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.TextColor3        = isUser
        and Color3.fromRGB(100, 200, 255)
        or (sender == "System" and Color3.fromRGB(255, 200, 50) or Color3.fromRGB(210, 210, 210))
    label.FontFace          = Font.new([[rbxasset://fonts/families/Inconsolata.json]])
    label.TextSize          = 14
    label.TextWrapped       = true
    label.TextXAlignment    = Enum.TextXAlignment.Left
    label.TextYAlignment    = Enum.TextYAlignment.Top
    label.Text              = (sender ~= "" and (sender .. ": ") or "") .. message
    label.Parent            = G2L["ScrollingFrame_c"]

    -- Cálculo de altura baseado no texto real
    local sfWidth = G2L["ScrollingFrame_c"].AbsoluteSize.X - 16
    local bounds = TextService:GetTextSize(
        label.Text, 14, Enum.Font.Code,
        Vector2.new(sfWidth > 0 and sfWidth or 440, math.huge)
    )
    label.Size = UDim2.new(1, 0, 0, math.max(bounds.Y + 10, 22))

    ScrollToBottom()
    return label
end



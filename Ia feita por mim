-- Função genérica para requests com tratamento de erro padronizado
local function DoRequest(opts)
    local ok, res = pcall(function() return request(opts) end)
    if not ok or not res or not res.Body then
        return nil, "Erro: Falha na requisição ao servidor"
    end
    local dok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not dok then
        return nil, "Erro: Resposta inválida do servidor"
    end
    return data, nil
end

-- ── Pollinations (GRÁTIS, sem chave) ──────────────────────────────────────
local function CallPollinationsAPI(userMessage)
    local messages = {{ role = "system", content = SYSTEM_PROMPT }}
    for _, m in ipairs(conversationHistory) do
        table.insert(messages, m)
    end
    table.insert(messages, { role = "user", content = userMessage })

    local data, err = DoRequest({
        Url    = "https://text.pollinations.ai/openai",
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body   = HttpService:JSONEncode({ model = "openai", messages = messages, private = true })
    })
    if err then return err end
    if data and data.choices and data.choices[1] then
        return data.choices[1].message.content
    end
    return "Erro: Sem resposta da Pollinations"
end

-- ── Gemini ─────────────────────────────────────────────────────────────────
local function CallGeminiAPI(userMessage)
    if Api_Gemini == "" then
        return "❌ Defina getgenv().GeminiApi antes de executar"
    end
    local contents = {}
    for _, m in ipairs(conversationHistory) do
        table.insert(contents, {
            role  = m.role == "assistant" and "model" or "user",
            parts = {{ text = m.content }}
        })
    end
    table.insert(contents, { role = "user", parts = {{ text = userMessage }} })

    local data, err = DoRequest({
        Url    = "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=" .. Api_Gemini,
        Method = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body   = HttpService:JSONEncode({
            system_instruction = { parts = {{ text = SYSTEM_PROMPT }} },
            contents = contents
        })
    })
    if err then return err end
    if data and data.candidates and data.candidates[1] then
        return data.candidates[1].content.parts[1].text
    end
    if data and data.error then return "Gemini: " .. (data.error.message or "Erro desconhecido") end
    return "Erro: Sem resposta do Gemini"
end


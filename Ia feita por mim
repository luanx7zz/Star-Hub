    label.FontFace           = Font.new([[rbxasset://fonts/families/Inconsolata.json]])
    label.TextSize           = 14
    label.TextXAlignment     = Enum.TextXAlignment.Left
    label.Text               = currentAI .. ": ●○○"
    label.Parent             = G2L["ScrollingFrame_c"]
    ScrollToBottom()

    local running = true
    local step    = 0
    local patterns = {"●○○", "●●○", "●●●", "○●●", "○○●", "○○○"}

    task.spawn(function()
        while running and label and label.Parent do
            step = (step % #patterns) + 1
            label.Text = currentAI .. ": " .. patterns[step]
            task.wait(0.3)
        end
    end)

    return label, function() running = false end
end

